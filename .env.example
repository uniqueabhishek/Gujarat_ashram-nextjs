# Environment Configuration Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local or any file with secrets

# Database Connection (PostgreSQL on Neon)
# Get this from https://console.neon.tech/app/projects
# Format: postgresql://user:password@host/database
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-host.c-3.us-east-2.aws.neon.tech/neondb?channel_binding=require&sslmode=require"

# JWT Authentication
# Generate a strong random secret for production:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="24h"
COOKIE_NAME="ashram_token"

# Application Environment
NODE_ENV="development"

# Optional: API Base URL (comment out to use relative URLs)
# NEXT_PUBLIC_API_BASE="http://localhost:3000/api"

# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env.local
# 2. Update DATABASE_URL with your Neon database connection string
# 3. Update JWT_SECRET with a random string
# 4. Never commit .env.local file
# 5. Each developer should have their own .env.local

# SECURITY:
# - Never commit files with credentials
# - Never share connection strings
# - Rotate secrets regularly
# - Use separate database for testing
# - Use separate secrets for production

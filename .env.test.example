# Test Environment Configuration Template
# Copy this file to .env.test and fill in your test database values
# NEVER commit .env.test or any file with secrets

# Database Connection (Test Database)
# Use a SEPARATE test database from development
# Either use a Neon test branch or create neondb_test
# Format: postgresql://user:password@host/database_test
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-host.c-3.us-east-2.aws.neon.tech/neondb_test?channel_binding=require&sslmode=require"

# Test Environment
NODE_ENV="test"

# JWT (Test Secret - can be simple for testing)
JWT_SECRET="test-secret-key-for-testing-only"
JWT_EXPIRES_IN="24h"
COOKIE_NAME="ashram_test_token"

# Testing Mode
TEST_MODE="true"

# SETUP INSTRUCTIONS:
# 1. Copy this file:          cp .env.test.example .env.test
# 2. Create a Neon test branch or separate DB at https://console.neon.tech
# 3. Update DATABASE_URL with the test database connection string
# 4. Run tests:               pnpm test
# 5. Verify test DB:          pnpm db:verify
# 6. NEVER commit .env.test

# IMPORTANT:
# - Use SEPARATE database from development
# - Use SEPARATE database from production
# - Test data should not pollute development
# - Test data can be reset between test runs
# - Tests should clean up their own data
